{{- /* Shared PowerShell profile; included from Windows + Unix profile paths. */ -}}
{{- if eq .chezmoi.os "windows" -}}
# Use ~/.config for Neovim, Starship, Yazi (same layout as Linux/macOS).
if (-not $env:XDG_CONFIG_HOME) {
    $env:XDG_CONFIG_HOME = Join-Path $env:USERPROFILE '.config'
}
if (-not $env:XDG_DATA_HOME) {
    $env:XDG_DATA_HOME = Join-Path (Join-Path $env:USERPROFILE '.local') 'share'
}
if (-not $env:XDG_STATE_HOME) {
    $env:XDG_STATE_HOME = Join-Path (Join-Path $env:USERPROFILE '.local') 'state'
}
Invoke-Expression (&starship init powershell)
if (Get-Module -ListAvailable -Name Terminal-Icons) { Import-Module Terminal-Icons }
function Switch-DarkTheme {
    $registryPath = "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Themes\Personalize"
    $propertyName = "AppsUseLightTheme"
    if (!(Test-Path $registryPath)) { return }
    $currentValue = (Get-ItemProperty -Path $registryPath -Name $propertyName -ErrorAction SilentlyContinue).$propertyName
    if ($null -ne $currentValue) {
        $newValue = if ($currentValue -eq 1) { 0 } else { 1 }
        Set-ItemProperty -Path $registryPath -Name $propertyName -Value $newValue
    }
}
Set-Alias ToggleTheme Switch-DarkTheme
Set-Alias ex explorer
# Yazi: use Git for Windows' file.exe for MIME detection (needed for previews).
$gitFileOne = Join-Path $env:LOCALAPPDATA 'Programs\Git\usr\bin\file.exe'
if (Test-Path $gitFileOne) { $env:YAZI_FILE_ONE = $gitFileOne }
{{- else if eq .chezmoi.os "darwin" -}}
if (-not $env:XDG_CONFIG_HOME) {
    $env:XDG_CONFIG_HOME = Join-Path $env:HOME '.config'
}
# GUI apps (e.g. WezTerm) launch pwsh with a minimal PATH that excludes Homebrew,
# so `brew` isn't found via Get-Command. Locate it by absolute path (Apple
# Silicon, then Intel) and load its shellenv FIRST — this puts /opt/homebrew/bin
# on PATH so starship, zoxide, fastfetch, etc. below resolve.
$brewBin = @('/opt/homebrew/bin/brew', '/usr/local/bin/brew') |
    Where-Object { Test-Path $_ } | Select-Object -First 1
if ($brewBin) {
    (& $brewBin shellenv) | Invoke-Expression
}
$localBin = Join-Path $env:HOME '.local/bin'
if (Test-Path $localBin) {
    $env:PATH = "$localBin$([IO.Path]::PathSeparator)$env:PATH"
}
# GUI-launched pwsh also misses /usr/local/bin (login shells get it from
# /etc/paths) — home of app-installed CLIs like Ollama's symlink.
if (($env:PATH -split ':') -notcontains '/usr/local/bin') {
    $env:PATH = "${env:PATH}:/usr/local/bin"
}

Invoke-Expression (&starship init powershell)
if (Get-Module -ListAvailable -Name Terminal-Icons) { Import-Module Terminal-Icons }
if (Get-Command brew -ErrorAction SilentlyContinue) {
    $(brew shellenv) | Invoke-Expression
}
if (Get-Command cursor-agent -ErrorAction SilentlyContinue) {
    Set-Alias cura cursor-agent
}
{{- else -}}
# Linux and other Unix (pwsh)
if (-not $env:XDG_CONFIG_HOME) {
    $env:XDG_CONFIG_HOME = Join-Path $env:HOME '.config'
}
$localBin = Join-Path $env:HOME '.local/bin'
if (Test-Path $localBin) {
    $env:PATH = "$localBin$([IO.Path]::PathSeparator)$env:PATH"
}
Invoke-Expression (&starship init powershell)
if (Get-Module -ListAvailable -Name Terminal-Icons) { Import-Module Terminal-Icons }
if (Get-Command brew -ErrorAction SilentlyContinue) {
    $(brew shellenv) | Invoke-Expression
}
{{- end -}}

# zoxide: smarter cd; learns visited dirs and powers `z`/`zi` (and Yazi's `z`).
if (Get-Command zoxide -ErrorAction SilentlyContinue) {
    Invoke-Expression (& { (zoxide init powershell | Out-String) })
}

Set-Alias cz chezmoi
